&CONTROL
  calculation = 'scf',
  prefix      = 'graphene',
  outdir      = './temp',
  pseudo_dir  = './',
  tefield=.true.,
  dipfield=.true.,

/

&SYSTEM
  ibrav     = 4,
  celldm(1) = 4.654,
  celldm(3) = 3.0,
  nat  = 2,
  ntyp = 1,
  ecutwfc = 40.0,
  ecutrho = 400.0,
  occupations = 'smearing',
  smearing = 'gaussian',
  degauss = 0.01,
  edir=3,
  emaxpos=0.55,
  eopreg=0.06,
  eamp=0.00005882,

/

&ELECTRONS
  conv_thr = 1.0d-8

/

ATOMIC_SPECIES
  C  12.0107 C.pbe-n-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS alat
  C    0.000000    0.0000000   0.000000
  C    0.000000    0.5773503   0.000000

K_POINTS automatic
  9 9 1   0 0 0
